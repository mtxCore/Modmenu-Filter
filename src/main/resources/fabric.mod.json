{
  "schemaVersion": 1,
  "id": "mod_menu_filter",
  "version": "${version}",
  "name": "Mod Menu Filter",
  "description": "Tag-based mod filtering, favourites, profiles, and coloured badges for Mod Menu.",
  "authors": ["mtxCore"],
  "contact": {},
  "license": "MIT",
  "icon": "assets/mod_menu_filter/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.mtxCore.mod_menu_filter.client.ModMenuFilterClient"
    ],
    "modmenu": [
      "com.mtxCore.mod_menu_filter.client.ModMenuIntegration"
    ]
  },
  "mixins": [
    {
      "config": "mod_menu_filter.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}",
    "modmenu": "*",
    "cloth-config": "*"
  }
}
